# GEMINI_API_KEY: Required for Gemini AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional. Required for OpenAI integration channel.
# Set this variable in the Secrets panel of AI Studio UI.
OPENAI_API_KEY=""

# ANTHROPIC_API_KEY: Optional. Required for Anthropic Claude integration channel.
# Set this variable in the Secrets panel of AI Studio UI.
ANTHROPIC_API_KEY=""

# LOCAL_LLM_URL: Optional. Base endpoint for running local LLM channels (e.g. Ollama).
# Defaults to "http://localhost:11434/v1" if omitted.
LOCAL_LLM_URL="http://localhost:11434/v1"